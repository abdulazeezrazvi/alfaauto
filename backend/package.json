{
  "name": "alfa-api",
  "version": "1.0.0",
  "description": "ALFA WhatsApp SaaS Platform — Backend API",
  "scripts": {
    "dev":            "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":          "tsc",
    "start":          "node dist/server.js",
    "mock:whatsapp":  "ts-node-dev --respawn src/mock/mock-whatsapp.ts",
    "db:push":        "prisma db push",
    "db:seed":        "ts-node prisma/seed.ts",
    "db:studio":      "prisma studio",
    "db:reset":       "prisma db push --force-reset && npm run db:seed",
    "test":           "jest"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client":     "^5.0.0",
    "bcryptjs":           "^2.4.3",
    "bull":               "^4.12.0",
    "chromadb":           "^1.7.0",
    "cors":               "^2.8.5",
    "dotenv":             "^16.0.0",
    "express":            "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "googleapis":         "^128.0.0",
    "helmet":             "^7.0.0",
    "ioredis":            "^5.3.0",
    "jsonwebtoken":       "^9.0.0",
    "multer":             "^1.4.5",
    "node-cron":          "^3.0.0",
    "node-fetch":         "^2.7.0",
    "pdf-parse":          "^1.1.1",
    "razorpay":           "^2.9.0",
    "socket.io":          "^4.6.0",
    "winston":            "^3.11.0",
    "zod":                "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs":    "^2.4.0",
    "@types/cors":        "^2.8.0",
    "@types/express":     "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer":      "^1.4.0",
    "@types/node":        "^20.0.0",
    "@types/node-fetch":  "^2.6.0",
    "prisma":             "^5.0.0",
    "ts-node":            "^10.9.0",
    "ts-node-dev":        "^2.0.0",
    "typescript":         "^5.0.0"
  }
}
